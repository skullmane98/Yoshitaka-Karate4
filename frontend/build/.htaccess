# Yoshitaka Karate-Do — SPA host config for Hostinger (Apache / LiteSpeed)
# Solves two common deployment issues:
#   1. 403 Forbidden — caused by directory listing disabled + missing default
#      doc routing. We explicitly set index.html as the directory index and
#      grant read access to everything in the build folder.
#   2. React-Router deep links (e.g. /login, /dashboard/admin) returning 404
#      because the static host doesn't know those routes. We rewrite every
#      non-file/non-directory request back to /index.html so the SPA boots.

Options +FollowSymLinks -MultiViews
DirectoryIndex index.html

# Allow browsers + everyone to read all files in the deployed folder.
<IfModule mod_authz_core.c>
    Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Allow from all
</IfModule>

# SPA fallback — anything that's not a real file/folder loads index.html
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Don't rewrite real files or directories (assets, fonts, images, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Everything else → index.html (so React Router takes over)
    RewriteRule ^ index.html [L]
</IfModule>

# Long-cache hashed build assets, no-cache for index.html so deploys go live
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|jpg|jpeg|png|gif|svg|ico|webp)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# Optional gzip (LiteSpeed handles brotli automatically, this is the fallback)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
